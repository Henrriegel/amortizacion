{
  "name": "amortizacion",
  "version": "0.1.0",
  "private": true,
  "main": "src/background.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "table2excel": "^1.0.4",
    "vue": "^3.5.13",
    "vue-excel-xlsx": "^1.2.2",
    "vue-mathjax": "^0.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.henrriegel.amortizacion",
    "productName": "Amortizacion",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/background.js",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}